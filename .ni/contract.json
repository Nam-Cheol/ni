  "requirements": [
    {
      "id": "REQ-001",
      "title": "ni init creates docs/plan templates and .ni/contract.json",
      "status": "accepted"
    },
    {
      "id": "REQ-002",
      "title": "ni status returns BLOCKED, READY_WITH_DEFERRALS, or READY",
      "status": "accepted"
    },
    {
      "id": "REQ-003",
      "title": "ni end creates .ni/plan.lock.json with file hashes",
      "status": "accepted"
    },
    {
      "id": "REQ-004",
      "title": "ni run outputs a 4000-character-or-less prompt and does not execute in v0",
      "status": "accepted"
    },
    {
      "id": "REQ-005",
      "title": "repository-local skills exist for ni-start, ni-end, and ni-run",
      "status": "accepted"
    },
    {
      "id": "REQ-006",
      "title": "ni init accepts concept, prototype, mvp, beta, and production planning readiness profiles",
      "status": "accepted"
    }
  ],
  "decisions": [
    {
      "id": "DEC-001",
      "title": "ni is a project intent compiler",
      "status": "accepted"
    },
    {
      "id": "DEC-002",
      "title": "ni run compiles a prompt in v0",
      "status": "accepted"
    },
    {
      "id": "DEC-003",
      "title": "Codex skills are UX, CLI is authority",
      "status": "accepted"
    }
  ],
  "risks": [
    {
      "id": "RISK-001",
      "title": "Model self-approval",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Readiness is enforced by ni status and not by model judgment."
    },
    {
      "id": "RISK-002",
      "title": "Criteria weakening after lock",
      "severity": "high",
      "status": "accepted",
      "mitigation": "ni run verifies lock hashes and refuses stale docs."
    },
    {
      "id": "RISK-003",
      "title": "Codex lock-in",
      "severity": "medium",
      "status": "accepted",
      "mitigation": "Keep Codex skills outside kernel and avoid Codex-specific schema fields."
    },
    {
      "id": "RISK-004",
      "title": "Readiness profiles look like execution stages",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Document and validate profiles as planning readiness profiles only, with no runtime packets or agent execution semantics."
    }
  ],
  "evaluations": [
    {
      "id": "EVAL-001",
      "title": "ni init creates required files",
