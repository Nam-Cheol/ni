      "method": "CLI integration test"
    },
    {
      "id": "EVAL-013",
      "title": "feedback ingest does not change contract or lock",
      "method": "CLI integration test"
    },
    {
      "id": "EVAL-014",
      "title": "pressure ledger requires explicit promotion",
      "method": "pressure unit and CLI tests"
    },
    {
      "id": "EVAL-015",
      "title": "harness candidate lifecycle remains non-executing",
