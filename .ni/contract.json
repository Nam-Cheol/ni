  "requirements": [
    {
      "id": "REQ-001",
      "title": "ni init creates docs/plan templates, .ni/contract.json, readiness config, and inert ledger files",
      "status": "accepted"
    },
    {
      "id": "REQ-002",
      "title": "ni status returns BLOCKED, READY_WITH_DEFERRALS, or READY with active profile and product guidance",
      "status": "accepted"
    },
    {
      "id": "REQ-003",
      "title": "ni end creates .ni/plan.lock.json with hashes for the contract and required planning docs",
      "status": "accepted"
    },
    {
      "id": "REQ-004",
      "title": "ni run supports target, out, and max-chars options, outputs a 4000-character-or-less prompt, and does not execute in v1",
      "status": "accepted"
    },
    {
      "id": "REQ-005",
      "title": "repository-local skills exist for ni-start, ni-end, and ni-run with CLI authority boundaries",
      "status": "accepted"
    },
    {
      "id": "REQ-006",
      "title": "ni init accepts concept, prototype, mvp, beta, and production planning readiness profiles",
      "status": "accepted"
    },
    {
      "id": "REQ-007",
      "title": "related-work docs define ni as pre-runtime planning kernel, not a host enhancer, SPEC runner, evidence loop, or harness runtime",
      "status": "accepted"
    },
    {
      "id": "REQ-008",
      "title": "contract supports product_type, delivery_surfaces, and interaction_mode as planning guidance fields",
      "status": "accepted"
    },
    {
      "id": "REQ-009",
      "title": "target registry lists supported prompt and export targets deterministically",
      "status": "accepted"
    },
    {
      "id": "REQ-010",
      "title": "target exports require a valid lock, verify hashes, and write only downstream seed or handoff material",
      "status": "accepted"
    },
    {
      "id": "REQ-011",
      "title": "feedback ingest records downstream observations without modifying the contract or lock",
      "status": "accepted"
    },
    {
      "id": "REQ-012",
      "title": "pressure ledger makes planning pressure visible and requires explicit promotion before acceptance",
      "status": "accepted"
    },
    {
      "id": "REQ-013",
      "title": "harness candidates have propose, validate, accept, and retire states and must not execute inside ni core",
      "status": "accepted"
    },
    {
      "id": "REQ-014",
      "title": "relock requires an applied amendment tied to the current lock and archives the previous lock",
      "status": "accepted"
    },
    {
      "id": "REQ-015",
      "title": "diff and conflicts compare planning states and report deterministic contract conflicts",
      "status": "accepted"
    }
  ],
  "decisions": [
    {
      "id": "DEC-001",
      "title": "ni is a project intent compiler",
      "status": "accepted"
    },
    {
      "id": "DEC-002",
      "title": "ni run compiles a prompt in v0 and v1",
      "status": "accepted"
    },
    {
      "id": "DEC-003",
      "title": "Codex skills are UX, CLI is authority",
      "status": "accepted"
    },
    {
      "id": "DEC-004",
      "title": "Downstream targets are registry entries, not runtime adapters",
      "status": "accepted"
    },
    {
      "id": "DEC-005",
      "title": "Feedback and pressure are inert until amended",
      "status": "accepted"
    },
    {
      "id": "DEC-006",
      "title": "Harness candidates are derived proposals",
      "status": "accepted"
    },
    {
      "id": "DEC-007",
      "title": "Relock requires an applied amendment",
      "status": "accepted"
    },
    {
      "id": "DEC-008",
      "title": "Collaboration checks are deterministic",
      "status": "accepted"
    }
  ],
  "risks": [
    {
      "id": "RISK-001",
      "title": "Model self-approval",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Readiness is enforced by ni status and not by model judgment."
    },
    {
      "id": "RISK-002",
      "title": "Criteria weakening after lock",
      "severity": "high",
      "status": "accepted",
      "mitigation": "ni run and exports verify lock hashes; relock requires an applied amendment."
    },
    {
      "id": "RISK-003",
      "title": "Host or runtime lock-in",
      "severity": "medium",
      "status": "accepted",
      "mitigation": "Keep hosts and downstream runtimes as targets or UX surfaces, not kernel concepts."
    },
    {
      "id": "RISK-004",
      "title": "Readiness profiles look like execution stages",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Document and validate profiles as planning readiness profiles only, with no runtime packets or agent execution semantics."
    },
    {
      "id": "RISK-005",
      "title": "Target exports become execution state",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Exports require valid locks, avoid external binaries, and write only seed or handoff files."
    },
    {
      "id": "RISK-006",
      "title": "Feedback mutates accepted truth",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Feedback ingest must not modify .ni/contract.json or .ni/plan.lock.json."
    },
    {
      "id": "RISK-007",
      "title": "Pressure ledger becomes acceptance shortcut",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Pressure promotion is explicit and still requires amendment plus relock before accepted criteria change."
    },
    {
      "id": "RISK-008",
      "title": "Harness candidates become kernel runtime",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Harness candidates must require user acceptance, validation evidence, and non-execution inside ni core."
    },
    {
      "id": "RISK-009",
      "title": "Relock bypass",
      "severity": "high",
      "status": "accepted",
      "mitigation": "Relock refuses to replace an existing lock unless an applied amendment belongs to the current source lock."
    },
    {
      "id": "RISK-010",
      "title": "Collaboration checks rely on model judgment",
      "severity": "medium",
      "status": "accepted",
      "mitigation": "Diff and conflict checks are deterministic and contract-local."
    }
  ],
