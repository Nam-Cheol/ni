  "interaction_mode": "human_to_system",
  "project": {
    "id": "ni",
    "name": "ni",
    "purpose": "Compile planning conversations into a locked v1 planning contract covering readiness profiles, product types, downstream targets, feedback pressure, harness candidates, amendment/relock, and collaboration checks before any execution harness runs.",
    "status": "accepted"
  },
  "non_goals": [
    {
      "id": "NG-001",
      "title": "Do not implement a task runner before contract, readiness, lockfile, and prompt compiler exist."
    },
    {
      "id": "NG-002",
      "title": "Do not make Codex-specific behavior part of the kernel."
    },
    {
      "id": "NG-003",
      "title": "Do not let target exports create downstream runtime packets or call external tools."
    },
    {
      "id": "NG-004",
      "title": "Do not let feedback, pressure, or harness candidates mutate locked planning state without amendment and relock."
    }
  ],
