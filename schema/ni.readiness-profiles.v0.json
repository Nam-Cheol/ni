{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni.readiness-profiles.v0",
  "title": "NI readiness profiles v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "default_profile",
    "profiles"
  ],
  "properties": {
    "schema": {
      "const": "ni.readiness.profiles.v0"
    },
    "default_profile": {
      "type": "string",
      "enum": [
        "concept",
        "prototype",
        "mvp",
        "beta",
        "production"
      ]
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "issue_severity"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "concept",
              "prototype",
              "mvp",
              "beta",
              "production"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "issue_severity": {
            "type": "object",
            "propertyNames": {
              "pattern": "^[RD][0-9]{3}$"
            },
            "additionalProperties": {
              "type": "string",
              "enum": [
                "blocker",
                "deferral"
              ]
            }
          }
        }
      }
    }
  }
}
