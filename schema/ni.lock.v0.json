{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni.lock.v0",
  "title": "NI plan lockfile v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "locked_at",
    "source_of_truth",
    "readiness",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "ni.lock.v0"
    },
    "locked_at": {
      "type": "string",
      "format": "date-time"
    },
    "previous_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "locked_at"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "locked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "source_of_truth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "READY_WITH_DEFERRALS",
            "READY"
          ]
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
