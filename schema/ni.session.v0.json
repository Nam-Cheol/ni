{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni.session.v0",
  "title": "NI planning session state v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "active_planning_focus",
    "last_planning_summary",
    "pending_questions",
    "recent_decisions",
    "recent_risks",
    "last_readiness_status",
    "last_readiness_blockers",
    "last_updated_docs",
    "authority_order",
    "notes"
  ],
  "properties": {
    "schema": {
      "const": "ni.session.v0"
    },
    "active_planning_focus": {
      "type": "string"
    },
    "last_planning_summary": {
      "type": "string"
    },
    "pending_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "blocker"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OQ-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "blocker": {
            "type": "boolean"
          }
        }
      }
    },
    "recent_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DEC-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "accepted",
              "deferred",
              "rejected",
              "not_applicable"
            ]
          }
        }
      }
    },
    "recent_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RISK-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "accepted",
              "mitigated",
              "deferred",
              "rejected"
            ]
          }
        }
      }
    },
    "last_readiness_status": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "BLOCKED",
        "READY_WITH_DEFERRALS",
        "READY"
      ]
    },
    "last_readiness_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "last_updated_docs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authority_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planning_aid_only",
        "locked_docs",
        "completion",
        "raw_transcript"
      ],
      "properties": {
        "planning_aid_only": {
          "const": "Session state is a planning aid, not authority."
        },
        "locked_docs": {
          "const": "Session state must not override locked docs."
        },
        "completion": {
          "const": "Session state must not mark docs complete."
        },
        "raw_transcript": {
          "const": "Raw transcript is not the source of truth."
        }
      }
    }
  }
}
