{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni.contract.v0",
  "title": "NI planning contract v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "readiness_profile",
    "product_type",
    "delivery_surfaces",
    "interaction_mode",
    "project",
    "non_goals",
    "capabilities",
    "requirements",
    "decisions",
    "risks",
    "evaluations",
    "artifacts",
    "open_questions"
  ],
  "properties": {
    "schema": {
      "const": "ni.contract.v0"
    },
    "readiness_profile": {
      "type": "string",
      "enum": [
        "concept",
        "prototype",
        "mvp",
        "beta",
        "production"
      ]
    },
    "product_type": {
      "type": "string",
      "enum": [
        "software",
        "conversation_product",
        "research_protocol",
        "operations_process",
        "education_program",
        "document_product",
        "physical_product",
        "mixed"
      ]
    },
    "delivery_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "web",
          "cli",
          "api",
          "conversation",
          "document",
          "workflow",
          "human_service",
          "physical"
        ]
      }
    },
    "interaction_mode": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "purpose",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^NG-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "requirements",
          "evaluations",
          "risks",
          "artifacts"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CAP-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "accepted",
              "deferred",
              "rejected",
              "not_applicable"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^CAP-[0-9]{3}$"
            }
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REQ-[0-9]{3}$"
            }
          },
          "evaluations": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^EVAL-[0-9]{3}$"
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^RISK-[0-9]{3}$"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^ART-[0-9]{3}$"
            }
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "accepted",
              "deferred",
              "rejected",
              "not_applicable"
            ]
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DEC-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "accepted",
              "deferred",
              "rejected",
              "not_applicable"
            ]
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "status",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RISK-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "accepted",
              "deferred",
              "rejected",
              "not_applicable"
            ]
          },
          "mitigation": {
            "type": "string"
          }
        }
      }
    },
    "evaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "method"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EVAL-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "method": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ART-[0-9]{3}$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "blocker",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OQ-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "blocker": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
